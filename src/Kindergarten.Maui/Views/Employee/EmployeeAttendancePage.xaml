<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Kindergarten.Maui.Views.Employee.EmployeeAttendancePage"
             BackgroundColor="White"
             Title="الحضور والانصراف">

  <ScrollView>
    <VerticalStackLayout Padding="16" Spacing="12">

      <!-- Today Card -->
      <Border BackgroundColor="#0f172a" StrokeShape="RoundRectangle 16"
              Stroke="Transparent" Padding="20">
        <VerticalStackLayout Spacing="8">
          <Label x:Name="DateLabel" Text="" FontSize="13"
                 TextColor="#94a3b8" HorizontalOptions="Center"/>
          <Label x:Name="TimeLabel" Text="--:--" FontSize="42"
                 FontAttributes="Bold" TextColor="White"
                 HorizontalOptions="Center"/>
          <Label x:Name="StatusLabel" Text="" FontSize="13"
                 TextColor="#f97316" HorizontalOptions="Center"/>
          <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
            <VerticalStackLayout Grid.Column="0" Spacing="4">
              <Label Text="وقت الحضور" FontSize="11" TextColor="#64748b"
                     HorizontalOptions="Center"/>
              <Label x:Name="CheckInTimeLabel" Text="--:--" FontSize="18"
                     FontAttributes="Bold" TextColor="#22c55e"
                     HorizontalOptions="Center"/>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" Spacing="4">
              <Label Text="وقت الانصراف" FontSize="11" TextColor="#64748b"
                     HorizontalOptions="Center"/>
              <Label x:Name="CheckOutTimeLabel" Text="--:--" FontSize="18"
                     FontAttributes="Bold" TextColor="#3b82f6"
                     HorizontalOptions="Center"/>
            </VerticalStackLayout>
          </Grid>
        </VerticalStackLayout>
      </Border>

      <!-- Action Buttons -->
      <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
        <Button Grid.Column="0" x:Name="CheckInButton"
                Text="✅ تسجيل الحضور"
                BackgroundColor="#22c55e" TextColor="White"
                CornerRadius="12" HeightRequest="54"
                FontSize="14" FontAttributes="Bold"
                Clicked="OnCheckInClicked"/>
        <Button Grid.Column="1" x:Name="CheckOutButton"
                Text="🔴 تسجيل الانصراف"
                BackgroundColor="#ef4444" TextColor="White"
                CornerRadius="12" HeightRequest="54"
                FontSize="14" FontAttributes="Bold"
                Clicked="OnCheckOutClicked"/>
      </Grid>

      <!-- Attendance History -->
      <Label Text="سجل الحضور" FontSize="18"
             FontAttributes="Bold" TextColor="#0f172a"/>

      <CollectionView x:Name="AttendanceList" SelectionMode="None">
        <CollectionView.ItemTemplate>
          <DataTemplate>
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 12"
                    Stroke="#e2e8f0" Padding="16" Margin="0,0,0,8">
              <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="4">
                  <Label Text="{Binding Date, StringFormat='{0:dd/MM/yyyy}'}"
                         FontSize="15" FontAttributes="Bold" TextColor="#0f172a"/>
                  <Label Text="{Binding WorkingHours, StringFormat='ساعات العمل: {0}'}"
                         FontSize="13" TextColor="#64748b"/>
                </VerticalStackLayout>
                <Label Grid.Column="1" Text="{Binding Status}"
                       FontSize="13" FontAttributes="Bold"
                       TextColor="#f97316" VerticalOptions="Center"/>
              </Grid>
            </Border>
          </DataTemplate>
        </CollectionView.ItemTemplate>
      </CollectionView>

      <!-- Logout Button -->
      <Button Text="🚪 تسجيل الخروج"
              BackgroundColor="#f1f5f9" TextColor="#ef4444"
              CornerRadius="12" HeightRequest="50"
              FontSize="15" FontAttributes="Bold"
              Margin="0,8,0,0"
              Clicked="OnLogoutClicked"/>

    </VerticalStackLayout>
  </ScrollView>
</ContentPage>