<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Kindergarten.Maui.Views.Parent.ParentDashboardPage"
             BackgroundColor="White"
             Title="KMS">

  <ScrollView>
    <VerticalStackLayout Padding="16" Spacing="12">

      <!-- Welcome Card -->
      <Border BackgroundColor="#f97316" StrokeShape="RoundRectangle 16" Stroke="Transparent" Padding="20">
        <VerticalStackLayout Spacing="4">
          <Label x:Name="WelcomeLabel" Text="مرحباً" FontSize="22"
                 FontAttributes="Bold" TextColor="White"/>
          <Label x:Name="UserNameLabel" Text="" FontSize="16" TextColor="#fff7ed"/>
        </VerticalStackLayout>
      </Border>

      <!-- Stats -->
      <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
        <Border Grid.Column="0" BackgroundColor="White" StrokeShape="RoundRectangle 14"
                Stroke="#e2e8f0" Padding="16">
          <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
            <Label Text="👶" FontSize="28" HorizontalOptions="Center"/>
            <Label x:Name="ChildrenCountLabel" Text="0" FontSize="28"
                   FontAttributes="Bold" TextColor="#0f172a" HorizontalOptions="Center"/>
            <Label x:Name="ChildrenLabel" Text="الأطفال" FontSize="12"
                   TextColor="#64748b" HorizontalOptions="Center"/>
          </VerticalStackLayout>
        </Border>
        <Border Grid.Column="1" BackgroundColor="White" StrokeShape="RoundRectangle 14"
                Stroke="#e2e8f0" Padding="16">
          <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
            <Label Text="💳" FontSize="28" HorizontalOptions="Center"/>
            <Label x:Name="SubsCountLabel" Text="0" FontSize="28"
                   FontAttributes="Bold" TextColor="#0f172a" HorizontalOptions="Center"/>
            <Label x:Name="SubsLabel" Text="الاشتراكات" FontSize="12"
                   TextColor="#64748b" HorizontalOptions="Center"/>
          </VerticalStackLayout>
        </Border>
      </Grid>

      <!-- Children List -->
      <Label x:Name="MyChildrenLabel" Text="أطفالي" FontSize="18"
             FontAttributes="Bold" TextColor="#0f172a"/>

      <Border BackgroundColor="White" StrokeShape="RoundRectangle 14" Stroke="#e2e8f0">
        <VerticalStackLayout x:Name="ChildrenStack" Spacing="0"/>
      </Border>

      <!-- Subscriptions -->
      <Label x:Name="MySubsLabel" Text="اشتراكاتي" FontSize="18"
             FontAttributes="Bold" TextColor="#0f172a"/>

      <Border BackgroundColor="White" StrokeShape="RoundRectangle 14" Stroke="#e2e8f0">
        <VerticalStackLayout x:Name="SubsStack" Spacing="0"/>
      </Border>

      <!-- Logout -->
      <Button Text="🚪 تسجيل الخروج"
              BackgroundColor="#f1f5f9" TextColor="#ef4444"
              CornerRadius="12" HeightRequest="50"
              FontSize="15" FontAttributes="Bold"
              Margin="0,8,0,0"
              Clicked="OnLogoutClicked"/>
    </VerticalStackLayout>
  </ScrollView>
</ContentPage>