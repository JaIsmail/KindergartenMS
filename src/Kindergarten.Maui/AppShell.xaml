<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:auth="clr-namespace:Kindergarten.Maui.Views.Auth"
       xmlns:parent="clr-namespace:Kindergarten.Maui.Views.Parent"
       xmlns:driver="clr-namespace:Kindergarten.Maui.Views.Driver"
       xmlns:employee="clr-namespace:Kindergarten.Maui.Views.Employee"
       x:Class="Kindergarten.Maui.AppShell"
       FlyoutBehavior="Disabled">

  <Shell.Resources>
    <ResourceDictionary>
      <Style TargetType="Shell">
        <Setter Property="Shell.BackgroundColor" Value="#f97316"/>
        <Setter Property="Shell.ForegroundColor" Value="White"/>
        <Setter Property="Shell.TitleColor" Value="White"/>
        <Setter Property="Shell.TabBarBackgroundColor" Value="White"/>
        <Setter Property="Shell.TabBarForegroundColor" Value="#f97316"/>
        <Setter Property="Shell.TabBarUnselectedColor" Value="#94a3b8"/>
      </Style>
    </ResourceDictionary>
  </Shell.Resources>

  <!-- Login -->
  <ShellContent Route="login"
                ContentTemplate="{DataTemplate auth:LoginPage}"
                Shell.NavBarIsVisible="False"
                Shell.TabBarIsVisible="False"/>

  <!-- Parent Tabs -->
  <TabBar Route="parent" x:Name="parentTabs">
    <Tab Title="الرئيسية" Icon="home.png" Route="dashboard">
      <ShellContent ContentTemplate="{DataTemplate parent:ParentDashboardPage}"/>
    </Tab>
    <Tab Title="الملف الشخصي" Icon="profile.png" Route="profile">
      <ShellContent ContentTemplate="{DataTemplate parent:ProfilePage}"/>
    </Tab>
  </TabBar>

  <!-- Driver Tabs -->
  <TabBar Route="driver" x:Name="driverTabs">
    <Tab Title="الرحلات" Icon="bus.png" Route="trips">
      <ShellContent ContentTemplate="{DataTemplate driver:DriverTripsPage}"/>
    </Tab>
    <Tab Title="الملف الشخصي" Icon="profile.png" Route="profile">
      <ShellContent ContentTemplate="{DataTemplate driver:DriverProfilePage}"/>
    </Tab>
  </TabBar>

  <!-- Employee Tabs -->
  <TabBar Route="employee" x:Name="employeeTabs">
    <Tab Title="الحضور" Icon="clock.png" Route="attendance">
      <ShellContent ContentTemplate="{DataTemplate employee:EmployeeAttendancePage}"/>
    </Tab>
    <Tab Title="الملف الشخصي" Icon="profile.png" Route="profile">
      <ShellContent ContentTemplate="{DataTemplate employee:EmployeeProfilePage}"/>
    </Tab>
  </TabBar>

</Shell>