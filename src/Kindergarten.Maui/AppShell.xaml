<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:auth="clr-namespace:Kindergarten.Maui.Views.Auth"
       xmlns:parent="clr-namespace:Kindergarten.Maui.Views.Parent"
       xmlns:driver="clr-namespace:Kindergarten.Maui.Views.Driver"
       xmlns:employee="clr-namespace:Kindergarten.Maui.Views.Employee"
       x:Class="Kindergarten.Maui.AppShell">

  <Shell.Resources>
    <ResourceDictionary>
      <Style TargetType="Shell">
        <Setter Property="Shell.BackgroundColor" Value="#f97316"/>
        <Setter Property="Shell.ForegroundColor" Value="White"/>
        <Setter Property="Shell.TitleColor" Value="White"/>
        <Setter Property="Shell.TabBarBackgroundColor" Value="White"/>
        <Setter Property="Shell.TabBarForegroundColor" Value="#f97316"/>
      </Style>
    </ResourceDictionary>
  </Shell.Resources>

  <!-- Login (default) -->
  <ShellContent
    Route="login"
    ContentTemplate="{DataTemplate auth:LoginPage}"
    Shell.NavBarIsVisible="False"/>

  <!-- Parent -->
  <TabBar Route="parent">
    <Tab Title="الرئيسية" Icon="home.png">
      <ShellContent Route="dashboard"
        ContentTemplate="{DataTemplate parent:ParentDashboardPage}"/>
    </Tab>
  </TabBar>

  <!-- Driver -->
  <TabBar Route="driver">
    <Tab Title="الرحلات" Icon="bus.png">
      <ShellContent Route="trips"
        ContentTemplate="{DataTemplate driver:DriverTripsPage}"/>
    </Tab>
  </TabBar>

  <!-- Employee -->
  <TabBar Route="employee">
    <Tab Title="الحضور" Icon="clock.png">
      <ShellContent Route="attendance"
        ContentTemplate="{DataTemplate employee:EmployeeAttendancePage}"/>
    </Tab>
  </TabBar>

</Shell>